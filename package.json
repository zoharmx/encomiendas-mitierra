{
  "name": "encomiendas-mi-tierra",
  "version": "1.0.0",
  "private": true,
  "description": "Tracking de paquetería + panel administrativo — Encomiendas Mi Tierra",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verificar:seguridad": "node scripts/verificar-seguridad.mjs",
    "emu": "firebase emulators:start --only firestore,auth,storage --project demo-mitierra",
    "probar": "firebase emulators:exec --only firestore,auth --project demo-mitierra \"npm run probar:todo\"",
    "probar:todo": "node scripts/pruebas/reglas.mjs && tsx scripts/pruebas/flujo.mts",
    "reglas:deploy": "firebase deploy --only firestore:rules,firestore:indexes,storage"
  },
  "dependencies": {
    "firebase": "^11.2.0",
    "firebase-admin": "^13.0.2",
    "lucide-react": "^0.469.0",
    "next": "^15.1.4",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3"
  }
}
