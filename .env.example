# ============================================================================
#  Encomiendas Mi Tierra — variables de entorno
#
#  Copia este archivo a `.env.local` y llena los valores.
#  `.env.local` está en .gitignore: NUNCA se sube al repositorio.
#
#  IMPORTANTE: las NEXT_PUBLIC_* se incrustan en el JavaScript que descarga el
#  navegador durante `npm run build`. Tienen que estar definidas ANTES de
#  compilar, también en el servidor de despliegue.
# ============================================================================


# ---------------------------------------------------------------------------
#  1. Firebase — configuración del CLIENTE (navegador)
#
#  Dónde: Consola de Firebase → ⚙ Configuración del proyecto → Tus apps →
#         App web → "Configuración del SDK" (objeto firebaseConfig).
#
#  Estas SÍ son públicas por diseño; no son secretos. Cualquiera puede verlas
#  en el código de la página. Lo que protege los datos son firestore.rules,
#  no estas claves.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=


# ---------------------------------------------------------------------------
#  2. Firebase Admin — credenciales del SERVIDOR
#
#  ⚠ ESTO SÍ ES SECRETO. Da acceso TOTAL a la base de datos, saltándose todas
#    las reglas de seguridad. Si se filtra, se filtra el negocio completo.
#    Nunca lo pegues en un chat, ni lo subas a Git, ni lo pongas en una
#    variable NEXT_PUBLIC_*.
#
#  Dónde: Consola de Firebase → ⚙ Configuración del proyecto → Cuentas de
#         servicio → "Generar nueva clave privada" → descarga un .json.
#         De ese .json salen los tres valores de abajo.
#
#  La clave privada va TODA en una sola línea, entre comillas, con los saltos
#  de línea escritos como \n literales (así viene en el .json).
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"


# ---------------------------------------------------------------------------
#  3. Emuladores locales (solo desarrollo)
#
#  En `true`, la app se conecta a los emuladores de Firebase en vez de a la
#  base real. Úsalo para probar sin ensuciar los datos de producción.
#  Déjalo vacío o en `false` en el servidor de producción.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_USE_EMULATORS=false
